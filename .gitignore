# Build output
/build/

# CubeMX internal files
/.mxproject
/mx.scratch

# macOS metadata (unanchored — .DS_Store appears in every subdirectory)
.DS_Store

# IDE settings
/.settings/
/.vscode/

# CubeMX Eclipse settings (not needed for CMake builds)
/.project
/.cproject

# Compiled output (unanchored — build artifacts can appear in subdirectories)
*.elf
*.bin
*.hex
*.map
*.lst

# Object files
*.o
*.obj

# gcov / lcov coverage output (unanchored — coverage files appear alongside sources)
*.gcov
*.gcda
*.gcno
/lcov.info
/coverage/

# LVGL duplicate copy (anchored to root — avoids case-insensitive match on Middlewares/Third_Party/lvgl/)
/LVGL/

# LVGL files not needed for embedded build (mid-path slash makes these implicitly root-relative)
Middlewares/Third_Party/lvgl/tests/
Middlewares/Third_Party/lvgl/docs/
Middlewares/Third_Party/lvgl/examples/
Middlewares/Third_Party/lvgl/demos/
Middlewares/Third_Party/lvgl/scripts/
Middlewares/Third_Party/lvgl/libs/
Middlewares/Third_Party/lvgl/env_support/
Middlewares/Third_Party/lvgl/.github/
Middlewares/Third_Party/lvgl/.devcontainer/

# STM32 vendor libraries are committed so CI firmware build works
